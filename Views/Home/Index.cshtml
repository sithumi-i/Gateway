</div>


<!-- ═══════════════════════════════════════════════════════════
     SECTION 2: HOW IT WORKS (3-STEP FLOW)
     ═══════════════════════════════════════════════════════════ -->
<div style="padding:5rem 0;position:relative;z-index:1;">
    <div style="text-align:center;max-width:600px;margin:0 auto 3.5rem;">
        <div style="font-size:.65rem;font-weight:800;text-transform:uppercase;letter-spacing:.12em;color:var(--primary);margin-bottom:.75rem;">How It Works</div>
        <h2 style="font-size:2.2rem;font-weight:900;letter-spacing:-.03em;margin-bottom:1rem;">Three Steps to a Fair Match</h2>
        <p style="font-size:.95rem;color:var(--on-surface-variant);">Our blind-match protocol ensures every student project is evaluated on its academic merit — never on who submitted it.</p>
    </div>

    <div class="row g-0" style="max-width:960px;margin:0 auto;">
        <!-- Step 1 -->
        <div class="col-md-4" style="padding:0 1rem;">
            <div style="text-align:center;padding:2.5rem 1.5rem;">
                <div style="width:64px;height:64px;border-radius:50%;background:var(--primary-container);display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;color:var(--primary);position:relative;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    <div style="position:absolute;top:-4px;right:-4px;width:22px;height:22px;border-radius:50%;background:var(--primary);color:#fff;font-size:.65rem;font-weight:900;display:flex;align-items:center;justify-content:center;">1</div>
                </div>
                <h4 style="font-size:1rem;font-weight:800;margin-bottom:.5rem;">Submit Your Proposal</h4>
                <p style="font-size:.82rem;line-height:1.65;">Students write a project title, abstract, select a research area, and list their technical stack. The identity is immediately redacted from supervisor view.</p>
            </div>
        </div>
        <!-- Step 2 -->
        <div class="col-md-4" style="padding:0 1rem;border-left:1px solid var(--outline-variant);border-right:1px solid var(--outline-variant);">
            <div style="text-align:center;padding:2.5rem 1.5rem;">
                <div style="width:64px;height:64px;border-radius:50%;background:var(--tertiary-container);display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;color:var(--tertiary);position:relative;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                    <div style="position:absolute;top:-4px;right:-4px;width:22px;height:22px;border-radius:50%;background:var(--tertiary);color:#fff;font-size:.65rem;font-weight:900;display:flex;align-items:center;justify-content:center;">2</div>
                </div>
                <h4 style="font-size:1rem;font-weight:800;margin-bottom:.5rem;">Blind Review</h4>
                <p style="font-size:.82rem;line-height:1.65;">Supervisors browse anonymized proposals that match their expertise. They can read the abstract, view the tech stack, but cannot see who submitted it.</p>
            </div>
        </div>
        <!-- Step 3 -->
        <div class="col-md-4" style="padding:0 1rem;">
            <div style="text-align:center;padding:2.5rem 1.5rem;">
                <div style="width:64px;height:64px;border-radius:50%;background:var(--success-container);display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;color:var(--success);position:relative;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                    <div style="position:absolute;top:-4px;right:-4px;width:22px;height:22px;border-radius:50%;background:var(--success);color:#fff;font-size:.65rem;font-weight:900;display:flex;align-items:center;justify-content:center;">3</div>
                </div>
                <h4 style="font-size:1rem;font-weight:800;margin-bottom:.5rem;">Identity Reveal & Match</h4>
                <p style="font-size:.82rem;line-height:1.65;">When a supervisor expresses interest, both parties are notified and identities are mutually revealed — creating a confirmed student–supervisor pairing.</p>
            </div>
        </div>
    </div>
</div>


<!-- ═══════════════════════════════════════════════════════════
     SECTION 3: KEY FEATURES (BENTO GRID)
     ═══════════════════════════════════════════════════════════ -->
