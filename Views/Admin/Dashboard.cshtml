@model IEnumerable<Gateway.BlindMatch.Models.ProjectProposal>
@{
    ViewData["Title"] = "Allocation Oversight – Admin Dashboard";
    int totalStudents    = ViewBag.TotalStudents  ?? 0;
    int totalSupervisors = ViewBag.TotalSupervisors ?? 0;
    int totalProposals   = ViewBag.TotalProposals  ?? 0;
    int matchedCount     = ViewBag.MatchedCount    ?? 0;
    double matchPercent  = ViewBag.MatchPercent    ?? 0.0;
    int pendingCount     = totalProposals - matchedCount;
}

<!-- ═══ HEADER ═══════════════════════════════════════════════ -->
<div class="dashboard-header">
    <div>
        <h1>Allocation Oversight</h1>
        <p>Curating academic excellence through precise project matching.</p>
    </div>
    <div class="header-actions">
        <a asp-controller="ResearchAreas" asp-action="Index" class="btn btn-secondary-ghost">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7"/></svg>
            Manage Tags
        </a>
        <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-gradient">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3l14 9-14 9V3z"/></svg>
            Refresh Report
        </a>
    </div>
</div>

<!-- ═══ STAT GRID ════════════════════════════════════════════ -->
<div class="stat-grid" style="grid-template-columns: repeat(4, 1fr);">

    <div class="stat-card accent-primary">
        <div>
            <div class="stat-label">Total Students</div>
            <div class="stat-value">@totalStudents</div>
        </div>
        <div class="stat-meta">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            +12% from last cycle
        </div>
    </div>

    <div class="stat-card accent-secondary">
        <div>
            <div class="stat-label">Supervisors</div>
            <div class="stat-value">@totalSupervisors</div>
        </div>
        <div class="stat-meta">Capacity: Active</div>
    </div>

    <div class="stat-card accent-primary">
        <div>
            <div class="stat-label">Total Proposals</div>
            <div class="stat-value">@totalProposals</div>
        </div>
        <div class="stat-meta">@pendingCount pending intervention</div>
    </div>

    <div class="stat-card" style="background: var(--surface-container-low); grid-column: span 1;">
        <div style="position: relative; z-index: 1;">
            <div class="stat-label">Match Percentage</div>
            <div class="stat-value primary">@matchPercent%</div>
            <div class="stat-bar-container">
                <div class="stat-bar" style="width:@(matchPercent)%"></div>
            </div>
            <div class="stat-meta" style="margin-top:.5rem;">@matchedCount matched · @pendingCount unmatched</div>
        </div>
        <div class="stat-icon-bg">
            <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/></svg>
        </div>
    </div>
</div>

<!-- ═══ ALLOCATION TABLE ══════════════════════════════════════ -->
<div class="section-card">
    <div class="section-card-header">
        <h2 class="section-card-title">Project Allocations</h2>
        <div class="search-bar-wrapper">
            <div class="search-input-wrap">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input class="search-input" id="tableSearch" placeholder="Search projects or names…" type="text" oninput="filterTable()" />
            </div>
            <select class="filter-select" id="statusFilter" onchange="filterTable()">
                <option value="">Status: All</option>
                <option value="Matched">Matched</option>
                <option value="Pending">Pending</option>
                <option value="UnderReview">Under Review</option>
            </select>
        </div>
    </div>

    <div class="data-table-wrap">
        <table class="data-table" id="allocationTable">
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Project / Proposal Title</th>
                    <th>Research Area</th>
                    <th>Supervisor</th>
                    <th>Status</th>
                    <th>Document</th>
                    <th style="text-align:right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var studentInitials = item.Student?.FullName is { Length: > 0 } fn
                        ? string.Concat(fn.Split(' ').Where(w => w.Length > 0).Take(2).Select(w => w[0]))
                        : "?";
                    var supervisorInitials = item.Supervisor?.FullName is { Length: > 0 } sn
                        ? string.Concat(sn.Split(' ').Where(w => w.Length > 0).Take(2).Select(w => w[0]))
                        : "?";

                    var statusClass = item.Status switch
                    {
                        Gateway.BlindMatch.Models.ProjectStatus.Matched     => "status-matched",
                        Gateway.BlindMatch.Models.ProjectStatus.UnderReview => "status-review",
                        _                                                    => "status-pending"
                    };
                    var statusLabel = item.Status switch
                    {
                        Gateway.BlindMatch.Models.ProjectStatus.Matched     => "Matched",
                        Gateway.BlindMatch.Models.ProjectStatus.UnderReview => "Under Review",
                        _                                                    => "Pending"
                    };
                    <tr>
                        <td>
                            <div style="display:flex;align-items:center;gap:.6rem;">
                                <div class="avatar">@studentInitials</div>
                                <div>
                                    <div style="font-weight:700;font-size:.8rem;">@item.Student?.FullName</div>
                                    <div style="font-size:.7rem;color:var(--text-secondary);">@item.Student?.Email</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div style="font-weight:800;font-size:.85rem;color:var(--on-surface);">@item.Title</div>
                            <div style="font-size:.7rem;color:var(--text-secondary);margin-top:.15rem;">@item.TechnicalStack</div>
                        </td>
                        <td>
                            <span class="badge-area">@item.ResearchArea?.Name</span>
                        </td>
                        <td>
                            <div style="display:flex;align-items:center;gap:.6rem;">
                                <div class="avatar" style="background:var(--secondary-container);color:var(--primary);">@supervisorInitials</div>
                                @if (item.Supervisor != null)
                                {
                                    <span style="font-size:.85rem;font-weight:600;">@item.Supervisor.FullName</span>
                                }
                                else
                                {
                                    <span style="font-size:.85rem;font-style:italic;color:var(--text-secondary);">Unassigned</span>
                                }
                            </div>
                        </td>
                        <td>
                            <span class="status-pill @statusClass">
                                <span class="status-pill-dot"></span>
                                @statusLabel
                            </span>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.DocumentPath))
                            {
                                <a href="@item.DocumentPath" target="_blank" class="btn btn-sm" title="Download Document"
                                   style="background:var(--primary-container);color:var(--primary);padding:.35rem .7rem;font-size:.72rem;font-weight:700;">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                                    View File
                                </a>
                            }
                            else
                            {
                                <span style="font-size:.78rem;color:var(--text-secondary);">—</span>
                            }
                        </td>
                        <td style="text-align:right;">
                            @if (item.Supervisor != null)
                            {
                                <form asp-action="Reassign" asp-controller="Admin" method="post" style="display:inline;">
                                    <input type="hidden" name="proposalId" value="@item.Id" />
                                    <button type="submit" class="btn btn-secondary-ghost btn-sm" title="Reassign">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span style="font-size:.78rem;font-weight:800;color:var(--primary);">Pending</span>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" style="text-align:center;padding:3rem;color:var(--text-secondary);font-style:italic;">
                            No proposals submitted yet.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="section-card-footer">
        <span style="font-size:.75rem;color:var(--text-secondary);font-weight:600;">Showing @Model.Count() allocations</span>
        <div class="pagination-btns">
            <button class="page-btn active">1</button>
        </div>
    </div>
</div>

<!-- ═══ CONFLICT RESOLUTION + LOCK ═══════════════════════════ -->
<div class="row g-4 mt-1">
    <div class="col-lg-8">
        <div class="section-card h-100">
            <div class="section-card-header">
                <h3 class="section-card-title">Conflict Resolution Center</h3>
            </div>
            <div class="section-card-body">
                <p style="font-size:.85rem;max-width:600px;margin-bottom:1.5rem;">
                    Review unmatched proposals below. Use manual assignment or prompt supervisor re-engagement.
                </p>
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="conflict-card critical">
                            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:.6rem;">
                                <span class="conflict-tag critical">Critical – Unmatched</span>
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="var(--error)" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                            </div>
                            <div style="font-weight:800;font-size:.85rem;margin-bottom:.35rem;">Proposals Awaiting Supervisor</div>
                            <div style="font-size:.78rem;color:var(--on-surface-variant);margin-bottom:1rem;">@pendingCount proposals with no match.</div>
                            <a asp-controller="ResearchAreas" asp-action="Index" class="btn btn-outline btn-sm" style="width:100%;justify-content:center;">Manage Research Areas</a>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="conflict-card moderate">
                            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:.6rem;">
                                <span class="conflict-tag moderate">Moderate – Review</span>
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="var(--text-secondary)" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                            </div>
                            <div style="font-weight:800;font-size:.85rem;margin-bottom:.35rem;">Under-Review Proposals</div>
                            <div style="font-size:.78rem;color:var(--on-surface-variant);margin-bottom:1rem;">@Model.Count(p => p.Status == Gateway.BlindMatch.Models.ProjectStatus.UnderReview) proposals under review.</div>
                            <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-primary btn-sm" style="width:100%;justify-content:center;">Refresh Dashboard</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="lock-card h-100">
            <div class="lock-bg-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="200" height="200" fill="currentColor" viewBox="0 0 24 24"><path d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/></svg>
            </div>
            <div style="position:relative;z-index:1;">
                <h3 style="font-size:1.1rem;margin-bottom:.6rem;">System Global Lock</h3>
                <p>Lock the allocation phase once matching thresholds are met. Current match rate: <strong style="color:#fff;">@matchPercent%</strong></p>
            </div>
            <div style="position:relative;z-index:1;margin-top:2rem;">
                <div class="lock-row lock-divider"><span>Matched Proposals</span><span>@matchedCount</span></div>
                <div class="lock-row lock-divider"><span>Pending</span><span>@pendingCount</span></div>
                <div class="lock-row lock-divider"><span>Total Proposals</span><span>@totalProposals</span></div>
                <button class="btn" style="width:100%;background:#fff;color:var(--primary);margin-top:1.25rem;justify-content:center;font-weight:800;padding:.85rem;" onclick="alert('Phase lock functionality coming soon!')">
                    Initiate Phase Lock
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function filterTable() {
    const q   = document.getElementById('tableSearch').value.toLowerCase();
    const st  = document.getElementById('statusFilter').value.toLowerCase();
    document.querySelectorAll('#allocationTable tbody tr').forEach(row => {
        const text = row.textContent.toLowerCase();
        const show = text.includes(q) && (st === '' || text.includes(st));
        row.style.display = show ? '' : 'none';
    });
}
</script>
}
