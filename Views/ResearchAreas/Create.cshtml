@model Gateway.BlindMatch.Models.ResearchArea
@{
    ViewData["Title"] = "Add Research Tag – Blind-Match PAS";
}

<!-- ═══ HEADER ═══════════════════════════════════════════════ -->
<div class="dashboard-header">
    <div>
        <div class="sr-label" style="color:var(--text-secondary);margin-bottom:.4rem;">Research Tags</div>
        <h1>Add New Research Area</h1>
        <p>Create a new tag that students and supervisors can use for proposal categorization and expertise matching.</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary-ghost">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Back to Tags
    </a>
</div>

<div class="row g-4">
    <!-- ═ FORM CARD ═══════════════════════════════════════════ -->
    <div class="col-lg-7">
        <div class="section-card">
            <div class="section-card-header">
                <h2 class="section-card-title">Tag Details</h2>
                <span class="badge-area">New Tag</span>
            </div>
            <div class="section-card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger" style="font-size:.85rem;margin-bottom:1rem;"></div>

                    <div class="form-field" style="margin-bottom:1.5rem;">
                        <label asp-for="Name" class="field-label">Research Area Name *</label>
                        <input asp-for="Name" class="field-input" placeholder="e.g. Machine Learning, Cybersecurity, Data Science…" autocomplete="off" />
                        <span asp-validation-for="Name" class="text-danger" style="font-size:.78rem;"></span>
                        <div class="field-hint">This name will appear as a selectable tag for students submitting proposals and supervisors defining their expertise.</div>
                    </div>

                    <div style="display:flex;gap:1rem;flex-wrap:wrap;padding-top:1.5rem;border-top:1px solid var(--outline-variant);">
                        <button type="submit" class="btn btn-gradient" style="padding:.8rem 2rem;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                            Create Research Area
                        </button>
                        <a asp-action="Index" class="btn btn-outline" style="padding:.8rem 1.5rem;">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ═ INFO SIDEBAR ════════════════════════════════════════ -->
    <div class="col-lg-5">
        <div class="protocol-box">
            <div style="font-size:.65rem;font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:var(--primary);margin-bottom:1.25rem;">Guidelines</div>

            <div class="protocol-item">
                <div class="protocol-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                    <div style="font-size:.82rem;font-weight:800;margin-bottom:.2rem;">Be Specific</div>
                    <div style="font-size:.78rem;color:var(--on-surface-variant);">Use precise, well-known academic discipline names. Avoid overly broad terms like "Engineering" or "Computing".</div>
                </div>
            </div>

            <div class="protocol-item">
                <div class="protocol-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                </div>
                <div>
                    <div style="font-size:.82rem;font-weight:800;margin-bottom:.2rem;">Used for Matching</div>
                    <div style="font-size:.78rem;color:var(--on-surface-variant);">Students select ONE area per proposal. Supervisors pick multiple areas of expertise. The system filters proposals accordingly.</div>
                </div>
            </div>

            <div class="protocol-item" style="margin-bottom:0;">
                <div class="protocol-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                </div>
                <div>
                    <div style="font-size:.82rem;font-weight:800;margin-bottom:.2rem;">Deletion Warning</div>
                    <div style="font-size:.78rem;color:var(--on-surface-variant);">Deleting an area may affect existing proposals tagged with it. Ensure no active proposals use a tag before removing it.</div>
                </div>
            </div>

            <div class="tip-box" style="margin-top:1.5rem;">
                <div style="font-size:.7rem;font-weight:800;color:var(--on-tertiary-container);margin-bottom:.4rem;">💡 EXAMPLE TAGS</div>
                <div style="display:flex;flex-wrap:wrap;gap:.4rem;">
                    @foreach (var tag in new[]{"Machine Learning","Cybersecurity","Data Science","IoT","NLP","Cloud Computing","Robotics","Bioinformatics"})
                    {
                        <span class="badge-area">@tag</span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
