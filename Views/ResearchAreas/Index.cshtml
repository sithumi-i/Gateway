@model IEnumerable<Gateway.BlindMatch.Models.ResearchArea>
@{
    ViewData["Title"] = "Research Areas";
}

<h1>Manage Research Areas</h1>
<p class="text-muted mb-4">Define the globally available tags for student proposals and supervisor expertise.</p>

<div class="mb-4">
    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-tag me-2" viewBox="0 0 16 16">
          <path d="M6 4.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0zm-1 0a.5.5 0 1 0-1 0 .5.5 0 0 0 1 0z"/>
          <path d="M2 1h4.586a1 1 0 0 1 .707.293l7 7a1 1 0 0 1 0 1.414l-4.586 4.586a1 1 0 0 1-1.414 0l-7-7A1 1 0 0 1 1 6.586V2a1 1 0 0 1 1-1zm0 5.586 7 7L13.586 9l-7-7H2v4.586z"/>
        </svg>Create New Area
    </a>
</div>

<div class="table-responsive">
<table class="table table-borderless align-middle">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Name)</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td><strong>@Html.DisplayFor(modelItem => item.Name)</strong></td>
        </tr>
}
    </tbody>
</table>
</div>
