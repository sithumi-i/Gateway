@{
    ViewData["Title"] = "Manage Expertise";
}

<h1>Manage Expertise</h1>
<p>Add research areas to your expertise profile to start receiving relevant blind proposals.</p>

<div class="row">
    <div class="col-md-4">
        <form asp-action="AddExpertise" method="post">
            <div class="form-group mb-3">
                <label class="control-label">Select Research Area</label>
                <select name="researchAreaId" class="form-control" asp-items="ViewBag.ResearchAreaId"></select>
            </div>
            <button type="submit" class="btn btn-primary">Add to Expertise</button>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Back to Dashboard</a>
</div>
