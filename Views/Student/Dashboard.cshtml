@model IEnumerable<Gateway.BlindMatch.Models.ProjectProposal>
@{
    ViewData["Title"] = "Student Portal – Dashboard";
    int matchedCount = ViewBag.MatchedCount ?? 0;
    int pendingCount = ViewBag.PendingCount ?? 0;
    string userName  = ViewBag.UserName ?? "Researcher";

    var matched = Model.Where(p => p.Status == Gateway.BlindMatch.Models.ProjectStatus.Matched).ToList();
    var pending = Model.Where(p => p.Status != Gateway.BlindMatch.Models.ProjectStatus.Matched).ToList();
}

<!-- ═══ HERO HEADER ══════════════════════════════════════════ -->
<div class="dashboard-header">
    <div>
        <div class="sr-label" style="color:var(--text-secondary);margin-bottom:.4rem;">Student Portal Overview</div>
        <h1>Welcome, @userName.Split(' ').First()</h1>
    </div>
    <div style="display:flex;gap:1rem;flex-wrap:wrap;">
        <div class="mini-stat-card">
            <div class="mini-stat-icon tertiary">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
                <div class="mini-stat-label">My Projects</div>
                <div class="mini-stat-value">@matchedCount Matched</div>
            </div>
        </div>
        <div class="mini-stat-card">
            <div class="mini-stat-icon primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
                <div class="mini-stat-label">In Review</div>
                <div class="mini-stat-value">@pendingCount Pending</div>
            </div>
        </div>
    </div>
</div>

<!-- ═══ ACTIVE MATCH ═════════════════════════════════════════ -->
@if (matched.Any())
{
    var m = matched.First();
    <div class="section-header" style="margin-bottom:1.25rem;">
        <h3>Active Match</h3>
        <div class="section-divider"></div>
    </div>

    <div class="match-hero-card" style="margin-bottom:2.5rem;">
        <div class="match-hero-image">
            <img src="https://picsum.photos/seed/@(m.Id + 10)/800/600" alt="Matched Project" referrerpolicy="no-referrer" />
            <div class="match-hero-image-overlay"></div>
            <div class="match-hero-image-text">Matched</div>
        </div>
        <div class="match-hero-body">
            <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:.75rem;">
                <span class="status-pill" style="background:var(--tertiary);color:var(--on-tertiary);">
                    <span style="width:6px;height:6px;border-radius:50%;background:var(--on-tertiary);"></span>
                    Matched
                </span>
                <span style="font-size:.72rem;color:var(--text-secondary);">Project #@m.Id</span>
            </div>
            <h2 style="font-size:1.7rem;margin-bottom:.85rem;">@m.Title</h2>
            <p style="font-size:.85rem;line-height:1.7;margin-bottom:1.25rem;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">@m.Abstract</p>
            <div style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1.5rem;">
                <span class="badge-area">@m.ResearchArea?.Name</span>
                <span class="tag-chip">@m.TechnicalStack</span>
            </div>
            <div style="padding-top:1.25rem;border-top:1px solid var(--outline-variant);display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;">
                <div style="display:flex;align-items:center;gap:.6rem;">
                    <div class="avatar" style="background:var(--secondary-container);color:var(--primary);">
                        @{var si = m.Supervisor?.FullName is { Length: > 0 } s ? string.Concat(s.Split(' ').Take(2).Select(w => w[0])) : "S";}
                        @si
                    </div>
                    <div>
                        <div style="font-weight:700;font-size:.82rem;">@(m.Supervisor?.FullName ?? "—")</div>
                        <div style="font-size:.7rem;color:var(--text-secondary);">Your Supervisor · @(m.Supervisor?.Email ?? "")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- ═══ MY PROPOSALS ════════════════════════════════════════ -->
<div class="section-header" style="margin-bottom:1.25rem;">
    <h3>My Proposals</h3>
    <div class="section-divider"></div>
    <a asp-controller="Projects" asp-action="Index" style="white-space:nowrap;font-size:.82rem;font-weight:800;color:var(--primary);display:flex;align-items:center;gap:.35rem;">
        All Submissions
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </a>
</div>

<div class="row g-4" style="margin-bottom:2.5rem;">
    @if (pending.Any())
    {
        @foreach (var p in pending.Take(4))
        {
            <div class="col-md-6">
                <div class="proposal-card">
                    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1.25rem;">
                        <div style="width:44px;height:44px;background:var(--surface-container-high);border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;color:var(--text-secondary);">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                        </div>
                        <span class="status-pill status-pending">
                            <span class="status-pill-dot"></span>
                            Pending
                        </span>
                    </div>
                    <h4 style="font-size:1rem;font-weight:800;color:var(--on-surface);line-height:1.3;margin-bottom:.4rem;">@p.Title</h4>
                    <p style="font-size:.78rem;color:var(--text-secondary);font-weight:600;margin-bottom:.75rem;">@p.ResearchArea?.Name</p>
                    <p style="font-size:.8rem;line-height:1.6;margin-bottom:0;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">@p.Abstract</p>
                    <div class="proposal-card-footer">
                        <span style="font-size:.7rem;color:var(--on-surface-variant);font-weight:500;">@p.TechnicalStack</span>
                        <span style="font-size:.7rem;color:var(--on-surface-variant);display:flex;align-items:center;gap:.3rem;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            Awaiting Review
                        </span>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div style="background:var(--surface-container-low);border-radius:var(--radius-md);padding:3rem;text-align:center;border:1px dashed var(--outline-variant);">
                <div style="font-size:.9rem;color:var(--text-secondary);margin-bottom:1.25rem;">No proposals yet. Start by submitting your first idea!</div>
                <a asp-controller="Projects" asp-action="Create" class="btn btn-primary">Submit a Proposal</a>
            </div>
        </div>
    }
</div>

<!-- ═══ HERO ACTION BANNER ════════════════════════════════════ -->
<div class="hero-action-banner">
    <div class="hero-orb" style="width:300px;height:300px;right:-100px;top:-120px;"></div>
    <div class="hero-orb" style="width:200px;height:200px;left:-80px;bottom:-80px;"></div>
    <div style="position:relative;z-index:1;">
        <h2>Ready to explore new avenues?</h2>
        <p>Our blind-match algorithm ensures your skills are paired with the most impactful research projects without bias.</p>
        <a asp-controller="Projects" asp-action="Create" class="btn" style="background:#fff;color:var(--primary);padding:.85rem 2rem;font-size:.9rem;font-weight:800;display:inline-flex;gap:.65rem;transition:transform 0.2s;" onmouseover="this.style.transform='scale(1.04)'" onmouseout="this.style.transform='scale(1)'">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
            Submit New Proposal
        </a>
    </div>
</div>
