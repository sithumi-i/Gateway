@using Microsoft.AspNetCore.Identity
@inject SignInManager<Gateway.BlindMatch.Models.ApplicationUser> SignInManager
@inject UserManager<Gateway.BlindMatch.Models.ApplicationUser> UserManager
@{
    ViewData["Title"] = "Home – Blind-Match PAS";
    bool isSignedIn = SignInManager.IsSignedIn(User);
}

<!-- ═══ HERO ══════════════════════════════════════════════════ -->
<div style="min-height:80vh;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;padding:4rem 1rem;">

    <!-- Orb decorations -->
    <div style="position:fixed;top:-100px;right:-150px;width:500px;height:500px;background:radial-gradient(circle, rgba(114,150,164,.12) 0%, transparent 70%);pointer-events:none;z-index:0;"></div>
    <div style="position:fixed;bottom:-100px;left:-150px;width:400px;height:400px;background:radial-gradient(circle, rgba(93,159,175,.08) 0%, transparent 70%);pointer-events:none;z-index:0;"></div>

    <div style="position:relative;z-index:1;max-width:700px;">
        <!-- Badge -->
        <div style="display:inline-flex;align-items:center;gap:.5rem;background:var(--primary-container);border:1px solid rgba(114,150,164,.2);border-radius:999px;padding:.4rem 1rem;margin-bottom:2rem;">
            <div style="width:6px;height:6px;border-radius:50%;background:var(--tertiary);"></div>
            <span style="font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:var(--primary);">PUSL2020 Coursework 2026/2027</span>
        </div>

        <h1 style="font-size:3.5rem;font-weight:900;line-height:1.1;margin-bottom:1.25rem;letter-spacing:-.035em;">
            The Blind-Match<br/>
            <span style="color:var(--primary);">Project Approval</span> System
        </h1>

        <p style="font-size:1.05rem;line-height:1.7;color:var(--on-surface-variant);max-width:560px;margin:0 auto 2.5rem;">
            A fair, merit-based platform where students propose research ideas and supervisors discover them <em>without bias</em> — identities revealed only at the moment of mutual match.
        </p>

        @if (!isSignedIn)
        {
            <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-gradient" style="padding:.85rem 2.25rem;font-size:.95rem;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/></svg>
                    Sign In to Portal
                </a>
                <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline" style="padding:.85rem 2rem;font-size:.95rem;">
                    Create Account
                </a>
            </div>
        }
        else
        {
            <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
                @if (User.IsInRole("Student"))
                {
                    <a asp-controller="Student" asp-action="Dashboard" class="btn btn-gradient" style="padding:.85rem 2.25rem;font-size:.95rem;">Go to My Dashboard</a>
                    <a asp-controller="Projects" asp-action="Create" class="btn btn-outline" style="padding:.85rem 2rem;font-size:.95rem;">Submit a Proposal</a>
                }
                @if (User.IsInRole("Supervisor"))
                {
                    <a asp-controller="Supervisor" asp-action="Index" class="btn btn-gradient" style="padding:.85rem 2.25rem;font-size:.95rem;">Review Proposals</a>
                    <a asp-controller="Supervisor" asp-action="Expertise" class="btn btn-outline" style="padding:.85rem 2rem;font-size:.95rem;">Manage Expertise</a>
                }
                @if (User.IsInRole("System Administrator") || User.IsInRole("Module Leader"))
                {
                    <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-gradient" style="padding:.85rem 2.25rem;font-size:.95rem;">Allocation Dashboard</a>
                    <a asp-controller="ResearchAreas" asp-action="Index" class="btn btn-outline" style="padding:.85rem 2rem;font-size:.95rem;">Manage Research Tags</a>
                }
            </div>
        }
    </div>

    <!-- Feature Cards -->
    <div class="row g-4 mt-5" style="max-width:960px;position:relative;z-index:1;">
        <div class="col-md-4">
            <div style="background:var(--surface);border-radius:var(--radius-md);padding:1.75rem;text-align:left;box-shadow:var(--shadow-sm);border:1px solid var(--outline-variant);">
                <div style="width:42px;height:42px;border-radius:var(--radius-sm);background:var(--primary-container);display:flex;align-items:center;justify-content:center;color:var(--primary);margin-bottom:1rem;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                </div>
                <h4 style="font-size:.95rem;font-weight:800;margin-bottom:.5rem;">Blind Review</h4>
                <p style="font-size:.8rem;margin:0;">Supervisors browse proposals without seeing student identities — pure merit-based evaluation.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div style="background:var(--surface);border-radius:var(--radius-md);padding:1.75rem;text-align:left;box-shadow:var(--shadow-sm);border:1px solid var(--outline-variant);">
                <div style="width:42px;height:42px;border-radius:var(--radius-sm);background:var(--tertiary-container);display:flex;align-items:center;justify-content:center;color:var(--tertiary);margin-bottom:1rem;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                </div>
                <h4 style="font-size:.95rem;font-weight:800;margin-bottom:.5rem;">Smart Matching</h4>
                <p style="font-size:.8rem;margin:0;">Proposals are surfaced to supervisors based on their declared research expertise areas.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div style="background:var(--surface);border-radius:var(--radius-md);padding:1.75rem;text-align:left;box-shadow:var(--shadow-sm);border:1px solid var(--outline-variant);">
                <div style="width:42px;height:42px;border-radius:var(--radius-sm);background:var(--success-container);display:flex;align-items:center;justify-content:center;color:var(--success);margin-bottom:1rem;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                </div>
                <h4 style="font-size:.95rem;font-weight:800;margin-bottom:.5rem;">Identity Reveal</h4>
                <p style="font-size:.8rem;margin:0;">Full identity disclosure happens only when a supervisor confirms interest — creating a mutual match.</p>
            </div>
        </div>
    </div>
</div>
