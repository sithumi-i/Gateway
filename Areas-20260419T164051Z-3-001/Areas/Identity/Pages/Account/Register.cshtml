@page
@model RegisterModel
@{
    ViewData["Title"] = "Create Account";
}

<style>
    .auth-wrapper {
        min-height: calc(100vh - 90px);
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
        margin: -2rem -1rem;
    }
    @@media (max-width: 991px) { .auth-wrapper { grid-template-columns: 1fr; } .auth-brand-panel { display: none; } }

    .auth-brand-panel {
        background: linear-gradient(135deg, #5D9FAF 0%, var(--primary) 50%, var(--primary-dim) 100%);
        color: var(--on-primary);
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 4rem;
        position: relative;
        overflow: hidden;
    }
    .auth-brand-panel::before {
        content: '';
        position: absolute;
        bottom: -150px; right: -100px;
        width: 450px; height: 450px;
        border-radius: 50%;
        background: rgba(255,255,255,.05);
    }
    .auth-brand-panel::after {
        content: '';
        position: absolute;
        top: -100px; left: -60px;
        width: 280px; height: 280px;
        border-radius: 50%;
        background: rgba(255,255,255,.04);
    }
    .auth-brand-panel h2 {
        color: #fff;
        font-size: 2.5rem;
        font-weight: 900;
        letter-spacing: -.03em;
        margin-bottom: 1rem;
        position: relative; z-index: 1;
    }
    .auth-brand-panel p {
        color: rgba(230,240,242,.85);
        font-size: 1rem;
        line-height: 1.7;
        max-width: 400px;
        position: relative; z-index: 1;
    }

    .role-cards {
        margin-top: 2.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        position: relative; z-index: 1;
    }
    .role-card {
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 12px;
        padding: 1.25rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        transition: background .2s;
    }
    .role-card:hover {
        background: rgba(255,255,255,.14);
    }
    .role-icon {
        width: 42px; height: 42px;
        border-radius: 10px;
        background: rgba(255,255,255,.12);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .role-card h5 { color: #fff; font-size: .85rem; font-weight: 800; margin: 0 0 .15rem; }
    .role-card span { color: rgba(230,240,242,.65); font-size: .72rem; line-height: 1.4; }

    .auth-form-panel {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem 2rem;
        background: var(--base-bg);
    }
    .auth-form-box {
        width: 100%;
        max-width: 440px;
    }
    .auth-form-box .form-header { margin-bottom: 2rem; }
    .auth-form-box .form-header .brand-dot {
        display: inline-block; width: 10px; height: 10px;
        border-radius: 50%; background: var(--tertiary); margin-right: .5rem;
    }
    .auth-form-box .form-header .brand-name {
        font-weight: 900; font-size: .9rem;
        color: var(--primary); letter-spacing: -.02em;
    }
    .auth-form-box .form-header h1 {
        font-size: 2rem; font-weight: 900;
        margin: 1.25rem 0 .5rem; letter-spacing: -.03em;
    }
    .auth-form-box .form-header p {
        font-size: .88rem; color: var(--text-secondary);
    }

    .auth-field { margin-bottom: 1.25rem; }
    .auth-field label {
        display: block; font-size: .65rem; font-weight: 800;
        text-transform: uppercase; letter-spacing: .1em;
        color: var(--text-secondary); margin-bottom: .5rem;
    }
    .auth-field input[type="email"],
    .auth-field input[type="password"],
    .auth-field input[type="text"] {
        width: 100%; padding: .85rem 1rem;
        border: 2px solid var(--outline-variant); border-radius: 10px;
        font-family: var(--font-body); font-size: .9rem;
        color: var(--on-surface); background: var(--surface);
        transition: all .2s ease;
    }
    .auth-field input:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(114,150,164,.12);
        background: #fff;
    }
    .auth-field .text-danger {
        font-size: .72rem; margin-top: .3rem; display: block;
    }

    .auth-submit-btn {
        width: 100%; padding: .9rem;
        border: none; border-radius: 10px;
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dim) 100%);
        color: var(--on-primary);
        font-family: var(--font-body); font-size: .9rem; font-weight: 800;
        cursor: pointer; transition: all .25s ease;
        box-shadow: 0 4px 16px rgba(114,150,164,.3);
        display: flex; align-items: center; justify-content: center; gap: .6rem;
        margin-top: 1.75rem;
    }
    .auth-submit-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 28px rgba(114,150,164,.4);
    }

    .auth-links { margin-top: 2rem; text-align: center; }
    .auth-links a { color: var(--primary); font-weight: 700; font-size: .85rem; }
    .auth-links span { color: var(--text-secondary); font-size: .85rem; }

    .auth-divider { display: flex; align-items: center; gap: 1rem; margin: 1.5rem 0; }
    .auth-divider::before, .auth-divider::after { content: ''; flex: 1; height: 1px; background: var(--outline-variant); }
    .auth-divider span { font-size: .72rem; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; letter-spacing: .08em; }

    .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    @@media (max-width: 500px) { .field-row { grid-template-columns: 1fr; } }
</style>

<div class="auth-wrapper">
    <!-- LEFT: Branding Panel -->
    <div class="auth-brand-panel">
        <h2>Join the<br/>Community.</h2>
        <p>Create your account to submit research proposals, review projects, and participate in the blind-match allocation system.</p>

        <div class="role-cards">
            <div class="role-card">
                <div class="role-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
                </div>
                <div>
                    <h5>Student</h5>
                    <span>Submit proposals, track status, discover your matched supervisor</span>
                </div>
            </div>
            <div class="role-card">
                <div class="role-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
                </div>
                <div>
                    <h5>Supervisor</h5>
                    <span>Browse anonymized proposals and match with research talent</span>
                </div>
            </div>
            <div class="role-card">
                <div class="role-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                </div>
                <div>
                    <h5>Module Leader</h5>
                    <span>Oversee allocations and manage research area tags</span>
                </div>
            </div>
        </div>
    </div>

    <!-- RIGHT: Register Form -->
    <div class="auth-form-panel">
        <div class="auth-form-box">
            <div class="form-header">
                <div>
                    <span class="brand-dot"></span>
                    <span class="brand-name">Blind-Match PAS</span>
                </div>
                <h1>Create Account</h1>
                <p>Fill in the details below to get started.</p>
            </div>

            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert" style="font-size:.8rem;margin-bottom:1rem;"></div>

                <div class="auth-field">
                    <label asp-for="Input.FullName">Full Name</label>
                    <input asp-for="Input.FullName" placeholder="Your full name" />
                    <span asp-validation-for="Input.FullName" class="text-danger"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.Email">Email Address</label>
                    <input asp-for="Input.Email" autocomplete="username" placeholder="you@university.edu" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="field-row">
                    <div class="auth-field">
                        <label asp-for="Input.Password">Password</label>
                        <input asp-for="Input.Password" autocomplete="new-password" placeholder="••••••••" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                    <div class="auth-field">
                        <label asp-for="Input.ConfirmPassword">Confirm</label>
                        <input asp-for="Input.ConfirmPassword" autocomplete="new-password" placeholder="••••••••" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>

                <button id="registerSubmit" type="submit" class="auth-submit-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
                    Create Account
                </button>
            </form>

            <div class="auth-divider"><span>Or</span></div>

            <div class="auth-links">
                <span>Already have an account? </span>
                <a id="login-link" asp-area="Identity" asp-page="/Account/Login">Sign in here</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
