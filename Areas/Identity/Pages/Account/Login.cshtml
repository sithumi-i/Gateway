@page
@model LoginModel
@{
    ViewData["Title"] = "Sign In";
}

<style>
    /* Full-page auth layout */
    .auth-wrapper {
        min-height: calc(100vh - 90px);
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
        margin: -2rem -1rem;
    }
    @@media (max-width: 991px) { .auth-wrapper { grid-template-columns: 1fr; } .auth-brand-panel { display: none; } }

    .auth-brand-panel {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dim) 60%, #4A7280 100%);
        color: var(--on-primary);
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 4rem;
        position: relative;
        overflow: hidden;
    }
    .auth-brand-panel::before {
        content: '';
        position: absolute;
        top: -120px; right: -120px;
        width: 400px; height: 400px;
        border-radius: 50%;
        background: rgba(255,255,255,.06);
    }
    .auth-brand-panel::after {
        content: '';
        position: absolute;
        bottom: -80px; left: -80px;
        width: 300px; height: 300px;
        border-radius: 50%;
        background: rgba(255,255,255,.04);
    }
    .auth-brand-panel h2 {
        color: #fff;
        font-size: 2.5rem;
        font-weight: 900;
        letter-spacing: -.03em;
        margin-bottom: 1rem;
        position: relative; z-index: 1;
    }
    .auth-brand-panel p {
        color: rgba(230, 240, 242, .85);
        font-size: 1rem;
        line-height: 1.7;
        max-width: 400px;
        position: relative; z-index: 1;
    }
    .brand-features {
        margin-top: 3rem;
        position: relative; z-index: 1;
    }
    .brand-feature-item {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }
    .brand-feature-icon {
        width: 40px; height: 40px;
        border-radius: 10px;
        background: rgba(255,255,255,.12);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .brand-feature-item h5 { color: #fff; font-size: .85rem; font-weight: 800; margin: 0 0 .2rem; }
    .brand-feature-item span { color: rgba(230,240,242,.7); font-size: .78rem; }

    .auth-form-panel {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem 2rem;
        background: var(--base-bg);
    }
    .auth-form-box {
        width: 100%;
        max-width: 420px;
    }
    .auth-form-box .form-header {
        margin-bottom: 2.5rem;
    }
    .auth-form-box .form-header .brand-dot {
        display: inline-block;
        width: 10px; height: 10px;
        border-radius: 50%;
        background: var(--tertiary);
        margin-right: .5rem;
    }
    .auth-form-box .form-header .brand-name {
        font-weight: 900;
        font-size: .9rem;
        color: var(--primary);
        letter-spacing: -.02em;
    }
    .auth-form-box .form-header h1 {
        font-size: 2rem;
        font-weight: 900;
        margin: 1.25rem 0 .5rem;
        letter-spacing: -.03em;
    }
    .auth-form-box .form-header p {
        font-size: .88rem;
        color: var(--text-secondary);
    }

    .auth-field {
        margin-bottom: 1.5rem;
    }
    .auth-field label {
        display: block;
        font-size: .65rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .1em;
        color: var(--text-secondary);
        margin-bottom: .5rem;
    }
    .auth-field input[type="email"],
    .auth-field input[type="password"],
    .auth-field input[type="text"] {
        width: 100%;
        padding: .85rem 1rem;
        border: 2px solid var(--outline-variant);
        border-radius: 10px;
        font-family: var(--font-body);
        font-size: .9rem;
        color: var(--on-surface);
        background: var(--surface);
        transition: all .2s ease;
    }
    .auth-field input:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(114,150,164,.12);
        background: #fff;
    }
    .auth-field .text-danger {
        font-size: .72rem;
        margin-top: .3rem;
        display: block;
    }

    .auth-checkbox {
        display: flex;
        align-items: center;
        gap: .6rem;
        margin-bottom: 1.75rem;
    }
    .auth-checkbox input[type="checkbox"] {
        width: 18px; height: 18px;
        accent-color: var(--primary);
        cursor: pointer;
    }
    .auth-checkbox label {
        font-size: .82rem;
        color: var(--on-surface-variant);
        cursor: pointer;
        font-weight: 500;
    }

    .auth-submit-btn {
        width: 100%;
        padding: .9rem;
        border: none;
        border-radius: 10px;
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dim) 100%);
        color: var(--on-primary);
        font-family: var(--font-body);
        font-size: .9rem;
        font-weight: 800;
        cursor: pointer;
        transition: all .25s ease;
        box-shadow: 0 4px 16px rgba(114,150,164,.3);
        display: flex; align-items: center; justify-content: center; gap: .6rem;
    }
    .auth-submit-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 28px rgba(114,150,164,.4);
    }

    .auth-links {
        margin-top: 2rem;
        text-align: center;
    }
    .auth-links a {
        color: var(--primary);
        font-weight: 700;
        font-size: .85rem;
    }
    .auth-links span {
        color: var(--text-secondary);
        font-size: .85rem;
    }

    .auth-divider {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin: 1.5rem 0;
    }
    .auth-divider::before, .auth-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: var(--outline-variant);
    }
    .auth-divider span {
        font-size: .72rem;
        font-weight: 700;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: .08em;
    }
</style>

<div class="auth-wrapper">
    <!-- LEFT: Branding Panel -->
    <div class="auth-brand-panel">
        <h2>Welcome<br/>Back.</h2>
        <p>Sign in to continue managing your research proposals, reviewing blind submissions, or overseeing the allocation process.</p>
        <div class="brand-features">
            <div class="brand-feature-item">
                <div class="brand-feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                </div>
                <div>
                    <h5>Blind Matching</h5>
                    <span>Proposals evaluated on merit alone</span>
                </div>
            </div>
            <div class="brand-feature-item">
                <div class="brand-feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                </div>
                <div>
                    <h5>Secure Access</h5>
                    <span>Role-based access with full data protection</span>
                </div>
            </div>
            <div class="brand-feature-item">
                <div class="brand-feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                </div>
                <div>
                    <h5>Identity Reveal</h5>
                    <span>Mutual match triggers transparent disclosure</span>
                </div>
            </div>
        </div>
    </div>

    <!-- RIGHT: Login Form -->
    <div class="auth-form-panel">
        <div class="auth-form-box">
            <div class="form-header">
                <div>
                    <span class="brand-dot"></span>
                    <span class="brand-name">Blind-Match PAS</span>
                </div>
                <h1>Sign In</h1>
                <p>Enter your credentials to access the portal.</p>
            </div>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert" style="font-size:.8rem;margin-bottom:1rem;"></div>

                <div class="auth-field">
                    <label asp-for="Input.Email">Email Address</label>
                    <input asp-for="Input.Email" autocomplete="username" placeholder="you@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.Password">Password</label>
                    <input asp-for="Input.Password" autocomplete="current-password" placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="auth-checkbox">
                    <input asp-for="Input.RememberMe" />
                    <label asp-for="Input.RememberMe">Remember me on this device</label>
                </div>

                <button id="login-submit" type="submit" class="auth-submit-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/></svg>
                    Sign In to Portal
                </button>
            </form>

            <div class="auth-divider"><span>Or</span></div>

            <div class="auth-links">
                <span>Don't have an account? </span>
                <a id="register-link" asp-area="Identity" asp-page="/Account/Register" asp-route-returnUrl="@Model.ReturnUrl">Create one now</a>
            </div>
            <div class="auth-links" style="margin-top:.75rem;">
                <a id="forgot-password" asp-area="Identity" asp-page="/Account/ForgotPassword" style="font-size:.78rem;color:var(--text-secondary);font-weight:600;">Forgot your password?</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
